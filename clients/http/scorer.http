### go-lgbm-serving - scorer HTTP API (примеры для JetBrains HTTP Client)
#
# Сервис конвейера decline->explain. Эндпойнты: POST /score, GET /explain/{id},
# GET /metrics. Переменная {{host}} берётся из http-client.env.json: выбрать
# окружение "local" в выпадающем списке вверху редактора.
#
# Запуск сервиса (порт по умолчанию :8080):
#   make run
# или с каталогом кодов причин (читаемые code/label вместо обобщённых R<idx>):
#   go -C serving run ./cmd/scorer -model ../testdata/model.txt -codes ../testdata/codes.json
# без обучения/скачивания - на закоммиченной фикстуре RBA-модели:
#   go -C serving run ./cmd/scorer -model ../fixtures/model.txt -codes ../fixtures/codes.json
#
# Запрос на /score - плотный массив "features" из ровно 12 чисел в этом порядке
# (имена из model.txt feature_names):
#    0 rtt_ms            round-trip time входа, мс
#    1 login_successful  вход успешен (0/1)
#    2 hour              час суток (0-23)
#    3 dow               день недели (0-6)
#    4 n_prior_logins    число прошлых входов пользователя
#    5 secs_since_last   секунд с прошлого входа (-1 если первый)
#    6 is_new_country    новая страна для пользователя (0/1)
#    7 is_new_city       новый город (0/1)
#    8 is_new_asn        новый ASN (0/1)
#    9 is_new_os         новая ОС (0/1)
#   10 is_new_browser    новый браузер (0/1)
#   11 is_new_device     новый тип устройства (0/1)
#
# Решение: decline при margin > threshold (по умолчанию 0), иначе approve.
# Объяснение (SHAP) считается асинхронно вне горячего пути, поэтому /explain
# доступен только для отклонённых транзакций и лишь спустя мгновение после /score.

### POST /score - отклонение (margin > 0)
# Успешный вход, ничего "нового", но 1188 прошлых входов в 3 ночи -> margin 2.70.
# Ответ кладёт id отклонения в глобальную переменную для следующего /explain.
# @name score_decline
POST {{host}}/score
Content-Type: application/json

{
  "features": [384, 1, 3, 1, 1188, 809.6929932, 0, 0, 0, 0, 0, 0]
}

> {%
    client.test("200 OK", function () {
        client.assert(response.status === 200, "status " + response.status);
    });
    client.test("decision is decline", function () {
        client.assert(response.body.decision === "decline", "got " + response.body.decision);
    });
    client.global.set("declineId", response.body.id);
    client.log("decline id=" + response.body.id + " margin=" + response.body.margin);
%}

### GET /explain/{id} - коды причин последнего отклонения
# Требует, чтобы выше отработал score_decline (переменная declineId).
# Объяснение асинхронное: если сразу 404, повторить запрос через мгновение -
# id уже выдан, объяснение вот-вот будет сохранено воркером.
GET {{host}}/explain/{{declineId}}
Accept: application/json

> {%
    client.test("200 OK", function () {
        client.assert(response.status === 200, "status " + response.status);
    });
    client.test("has reason codes", function () {
        client.assert(response.body.reasons.length > 0, "no reasons");
    });
    client.log("top reason: " + response.body.reasons[0].code +
               " (" + response.body.reasons[0].direction + ")" +
               " base=" + response.body.base + " margin=" + response.body.margin);
%}

### POST /score - одобрение (margin <= 0)
# Вернувшийся пользователь, ничего нового -> margin сильно отрицательная.
# @name score_approve
POST {{host}}/score
Content-Type: application/json

{
  "features": [30, 1, 14, 2, 200, 3600, 0, 0, 0, 0, 0, 0]
}

> {%
    client.test("200 OK", function () {
        client.assert(response.status === 200, "status " + response.status);
    });
    client.test("decision is approve", function () {
        client.assert(response.body.decision === "approve", "got " + response.body.decision);
    });
    client.global.set("approveId", response.body.id);
%}

### GET /explain/{id} - 404 для одобренной транзакции
# Одобрения не объясняются, поэтому id из score_approve всегда даёт 404.
GET {{host}}/explain/{{approveId}}
Accept: application/json

> {%
    client.test("404 Not Found", function () {
        client.assert(response.status === 404, "status " + response.status);
    });
%}

### GET /explain/{id} - 404 для неизвестного id
GET {{host}}/explain/deadbeefdeadbeefdeadbeef
Accept: application/json

> {%
    client.test("404 Not Found", function () {
        client.assert(response.status === 404, "status " + response.status);
    });
%}

### GET /metrics - операционный снимок
# Счётчики горячего пути, глубина очереди explain и прогресс объяснителя.
GET {{host}}/metrics
Accept: application/json

> {%
    client.test("200 OK", function () {
        client.assert(response.status === 200, "status " + response.status);
    });
    client.log("scored=" + response.body.scored +
               " declined=" + response.body.declined +
               " decline_rate=" + response.body.decline_rate +
               " explained=" + response.body.explained +
               " queue_len=" + response.body.queue_len +
               " dropped=" + response.body.queue_dropped);
%}

### POST /score - 400: битый JSON
POST {{host}}/score
Content-Type: application/json

{ "features": [1, 2, 3

> {%
    client.test("400 Bad Request", function () {
        client.assert(response.status === 400, "status " + response.status);
    });
%}

### POST /score - 422: неверное число признаков (нужно ровно 12)
POST {{host}}/score
Content-Type: application/json

{
  "features": [1, 2, 3]
}

> {%
    client.test("422 Unprocessable Entity", function () {
        client.assert(response.status === 422, "status " + response.status);
    });
%}
